{
  "name": "ai-lead-generator-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=esm --target=es2022 --platform=neutral --conditions=worker,browser --jsx=automatic --jsx-import-source=hono/jsx --outfile=dist/_worker.js",
    "dev": "wrangler pages dev dist --compatibility-flags=nodejs_compat",
    "deploy": "npm run build && wrangler pages deploy dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  }
}
