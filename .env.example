# --- Supabase ---
SUPABASE_URL=https://hbbkhcafmdxprepzpqtt.supabase.co
SUPABASE_KEY=sb_publishable_67Rbe_i3ptkLx8piQh4PPw_HnG_wZWn
# Service role key required for server-side inserts that bypass RLS.
# Get it from Supabase dashboard -> Project Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Places API (Lead Hunter source) ---
# Enable "Places API (New)" in Google Cloud Console and create an API key.
GOOGLE_PLACES_API_KEY=

# --- Outreach sender identity (used in templates) ---
SENDER_NAME=Your Name
SENDER_COMPANY=Your Agency
SENDER_EMAIL=you@youragency.com
SENDER_CALENDAR_URL=https://cal.com/yourhandle/15min

# --- Gmail (SMTP for sending) ---
# 1) Enable 2FA on your Google account.
# 2) Visit https://myaccount.google.com/apppasswords and create an app password.
# 3) Paste the 16-char password (no spaces) here. Sender address = SENDER_EMAIL above.
GMAIL_APP_PASSWORD=

# --- Gmail IMAP (Reply Monitor — Agent 8) ---
# Reuses GMAIL_APP_PASSWORD by default. Override only if monitoring a different mailbox.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_MAX_PER_POLL=50

# --- WhatsApp is draft-only ---
# The dashboard generates WhatsApp message bodies; you copy them and send
# manually from your own WhatsApp. There is no Cloud API integration.

# --- Approval gates (set false to let the agent act without asking) ---
REQUIRE_APPROVAL_SENDS=true
REQUIRE_APPROVAL_REPLIES=true
REQUIRE_APPROVAL_DEMOS=true
REQUIRE_APPROVAL_BATCHES=true

# --- Runtime ---
LOG_LEVEL=INFO
